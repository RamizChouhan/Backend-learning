<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Management</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;

        }

        table {
            margin-top: 15px;
            border-collapse: collapse;
        }

        th,
        td {
            border: 1px solid black;
            padding: 10px;
        }
    </style>
</head>

<body>
    <h1>student details</h1>
    <table border="1px" cellpadding="10">
        <thead>
            <th>Id</th>
            <th>Name</th>
            <th>Course</th>
            <th>Standard</th>
            <th>Marks</th>

        </thead>

        <tbody>
            <% AllDetail.forEach(detail => { %>
                <tr>
                    <td>
                        <%= detail.Id %>
                    </td>
                    <td>
                        <%= detail.Name %>
                    </td>

                    <td>
                        <%= detail.Course %>
                    </td>
                    <td>
                        <%= detail.Standard %>
                    </td>
                    <td>
                        <%= detail.Marks %>
                    </td>
                </tr>
                <% }) %>
        </tbody>
    </table>


</body>

</html>