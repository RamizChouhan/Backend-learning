<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Student Details</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
    </style>
</head>
<body> 

    <h2>Fill Your Details</h2>
    <form action="/student" method="post">
         <label for="IdNo">ID :</label>
         <input type="number" name="Id" id="IdNo" placeholder="Enter Your Id No" required/><br><br>

          <label for="Name">Name :</label>
         <input type="text" name="Name" id="Name" placeholder="Enter Your Name :" required/><br><br>

          <label for="courseName">Course :</label>
         <input type="text" name="Course" id="courseName" placeholder="Enter Your Course Name :" required/><br><br>

          <label for="Standard">Standard :</label>
         <input type="text" name="Standard" id="Standard" placeholder="Enter Your Standard" required><br><br>

          <label for="Marksno">Marks :</label>
         <input type="text" name="Marks" id="Marksno" placeholder="Enter Your Marks" required><br><br>

         <button type="submit">Submit</button>
    </form>
</body>
</html>